# Copy this file to .env and fill in your token
# cp .env.example .env

# Get from: github.com → Settings → Developer Settings → Personal Access Tokens → Classic
# No special scopes needed — a blank token works for GitHub Models

GITHUB_TOKEN=ghp_your_token_here
FLASK_DEBUG=true
PORT=5000



# Azure AI Foundry (real Microsoft IQ integration)
AZURE_API_KEY=paste_your_key_here
AZURE_ENDPOINT=https://your-project.openai.azure.com/
AZURE_MODEL=gpt-4o

# GitHub Models fallback
GITHUB_MODEL=gpt-4o-mini
GITHUB_ENDPOINT=https://models.github.ai/inference/chat/completions
